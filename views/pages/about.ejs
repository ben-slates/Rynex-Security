<%- include('../partials/head', { title, description, canonicalPath, cssFile, structuredData }) %>
<body>
<%- include('../partials/navbar', { active }) %>

<!-- Navbar -->
    



    <!-- Page Header -->
    <div class="page-header">
        <div class="container">
            <h1 data-aos="zoom-out" data-aos-duration="1200">About Us</h1>
            <p style="margin-top:15px; color:#ccc; font-size:2rem;">
				Empowering cybersecurity through real-world expertise and advanced offensive security practices.
			</p>
        </div>
    </div>

    <!-- Company Introduction -->
    <section>
        <div class="container">
            <div class="about-content">
                <div class="about-text" data-aos="fade-right">
                    <div class="section-title" style="text-align: left;">
                        <h2>Our Legacy</h2>
                        <div class="underline" style="margin: 0;"></div>
                    </div>
                    <p style="text-align: justify;">Rynex Security was founded with a clear mission — to bring practical cybersecurity knowledge and real-world expertise to individuals and organizations. In a landscape where threats are constantly evolving, we focus on delivering solutions that work beyond theory.</p>
                    <p style="text-align: justify;">We are a community of ethical hackers, security researchers, and cybersecurity professionals dedicated to building strong defensive and offensive capabilities. Our approach is hands-on, realistic, and aligned with modern attack methodologies.</p>
                </div>
                <div class="about-image" data-aos="fade-left">
                    <img src="https://ik.imagekit.io/t4itchmhb/legacy.png" alt="Rynex Security Research Lab">
                </div>
            </div>
        </div>
    </section>

    <!-- Mission & Vision -->
    <section class="mission-vision">
        <div class="container">
            <div class="mv-grid">
                <div class="mv-card" data-aos="fade-up" data-aos-delay="100">
                    <i class="fas fa-bullseye"></i>
                    <h3>Our Mission</h3>
                    <p  style="text-align: justify;">To empower individuals and organizations with practical cybersecurity skills, advanced threat defense techniques, and real-world security solutions.</p>
                </div>
                <div class="mv-card" data-aos="fade-up" data-aos-delay="300">
                    <i class="fas fa-eye"></i>
                    <h3>Our Vision</h3>
                    <p  style="text-align: justify;">To become a leading cybersecurity platform recognized for innovation, hands-on training, and impactful security services across the region.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Founder Message -->
    <section class="founder-section">
        <div class="container">
            <div class="section-title" data-aos="fade-up">
                <h2>A Message from Our Founder</h2>
                <div class="underline"></div>
            </div>
            <div class="founder-card" data-aos="zoom-in">
                <i class="fas fa-quote-left quote-icon"></i>
                <p>"At Rynex Security, we believe that true security is not a product, but a process of continuous learning and adaptation. Our commitment is to provide the most rigorous, practical, and effective cybersecurity solutions in the industry. We don't just secure systems; we empower the people who run them."</p>
                <div class="founder-info">
                    <h4>Muhammad Hamza Zahid</h4>
                    <span>Founder & Chief Executive Officer</span>
                </div>
            </div>
        </div>
    </section>

            <!-- Footer -->
    



    <!-- Scripts -->

<%- include('../partials/footer') %>
<%- include('../partials/scripts', { externalScripts, localScript, contactScript }) %>
</body>
</html>
