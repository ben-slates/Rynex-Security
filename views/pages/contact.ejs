<%- include('../partials/head', { title, description, canonicalPath, cssFile, structuredData }) %>
<body>
<%- include('../partials/navbar', { active }) %>

    <div class="contact-page">
        <div class="contact-wrapper">

            <!-- Tagline -->
            <div class="contact-heading" data-aos="fade-up" data-aos-duration="600">
                <h1>Get In Touch</h1>
                <p>Describe your challenge — we'll respond within 24 hours.</p>
            </div>

            <!-- Form -->
            <div class="form-card" data-aos="fade-up" data-aos-duration="800" data-aos-delay="100">
                <form id="form" action="/api/contact" method="post">
                    <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;">

                    <div class="field-row">
                        <div class="field-group">
                            <label for="name">Name</label>
                            <input type="text" id="name" name="name" placeholder="Your name" required>
                        </div>
                        <div class="field-group">
                            <label for="email">Email</label>
                            <input type="email" id="email" name="email" placeholder="your@email.com" required>
                        </div>
                    </div>

                    <div class="field-group">
                        <label for="subject">Subject</label>
                        <input type="text" id="subject" name="subject" placeholder="e.g. VAPT consultation, SOC enquiry...">
                    </div>

                    <div class="field-group">
                        <label for="message">Message</label>
                        <textarea id="message" name="message" rows="5" placeholder="How can we help secure your business?" required></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary" id="submitBtn">
                        <i class="fas fa-paper-plane"></i>
                        Send Message
                    </button>
                    <p id="formStatus" style="margin-top:12px;font-size:0.9rem;color:#aaa;min-height:20px;"></p>
                </form>
            </div>

            <!-- Bottom Links -->
            <div class="contact-bottom">
                <a href="mailto:info@rynexsecurity.com" class="bottom-link">
                    <i class="fas fa-envelope"></i> info@rynexsecurity.com
                </a>
                <a href="tel:+923272873812" class="bottom-link">
                    <i class="fas fa-phone"></i> +92 327 287 3812
                </a>
                <div class="bottom-social">
                    <a href="https://www.linkedin.com/company/rynex-security" target="_blank" rel="noreferrer" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                    <a href="https://discord.gg/6xJdYsJ6uF" target="_blank" rel="noreferrer" aria-label="Discord"><i class="fab fa-discord"></i></a>
                    <a href="https://www.instagram.com/rynex.security" target="_blank" rel="noreferrer" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                </div>
            </div>

        </div>
    </div>

<%- include('../partials/footer') %>
<%- include('../partials/scripts', { externalScripts, localScript, contactScript }) %>
</body>
</html>
